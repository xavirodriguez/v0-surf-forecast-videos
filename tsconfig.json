{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "types": ["node"],
    "allowJs": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "outDir": "dist"
  },
  "include": ["src", "scripts"],
  "exclude": ["node_modules", "dist"]
}
